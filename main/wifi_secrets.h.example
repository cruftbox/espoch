/*
 * Template for main/wifi_secrets.h (which is git-ignored).
 *
 * To set up WiFi: copy this file to `wifi_secrets.h` in the same folder and
 * fill in your real 2.4 GHz network name and password. The real file is never
 * committed to git, so your password stays off GitHub.
 */
#pragma once

#define WIFI_SSID "YOUR_WIFI_NAME"
#define WIFI_PASS "YOUR_WIFI_PASSWORD"
